              "description": "根据用户提问召回对应的知识chunk",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "required": [
                        "query",
                        "knCodeList",
                        "topK",
                        "searchMode"
                      ],
                      "properties": {
                        "query": {
                          "type": "string",
                          "description": "需要检索的内容"
                        },
                        "knCodeList": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "知识库编码列表"
                        },
                        "topK": {
                          "type": "integer",
                          "minimum": 1,
                          "description": "最终返回条数，必须大于0"
                        },
                        "fileTypeList": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "按照文件类型过滤"
                        },
                        "searchMode": {
                          "type": "string",
                          "description": "检索模式：fullTextRecall全文检索，embedding语义检索，mixedRecall混合检索",
                          "enum": [
                            "fullTextRecall",
                            "embedding",
                            "mixedRecall"
                          ]
                        }
                      }
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "操作成功",
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "resultCode": {
                            "type": "string",
                            "description": "接口状态码，0成功，非0失败"
                          },
                          "resultMsg": {
                            "type": "string",
                            "description": "接口返回说明"
                          },
                          "resultObject": {
                            "type": "object",
                            "properties": {
                              "data": {
                                "type": "array",
                                "description": "检索结果列表",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "knCode": {
                                      "type": "string",
                                      "description": "知识库编码"
                                    },
                                    "filePath": {
                                      "type": "string",
                                      "description": "文档的全路径（以\"/\"开头，不包括知识库名称）"
                                    },
                                    "chunkNo": {
                                      "type": "integer",
                                      "description": "切片在文档中的编号"
                                    },
                                    "chunkId": {
                                      "type": "integer",
                                      "description": "切片的唯一编号"
                                    },
                                    "chunkText": {
                                      "type": "string",
                                      "description": "切片的文本内容"
                                    },
                                    "score": {
                                      "type": "integer",
                                      "description": "融合得分"
                                    },
                                    "imagePath": {
                                      "type": "string",
                                      "description": "图片的短地址URL，知识引擎负责将短地址URL映射为实际的地址URL"
                                    },
                                    "startLine": {
                                      "type": "integer",
                                      "description": "Markdown起始行"
                                    },
                                    "endLine": {
                                      "type": "integer",
                                      "description": "Markdown结束行"
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "openapiSchema": {
