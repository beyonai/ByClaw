                            "type": "string",
                            "description": "接口状态码，0成功，非0失败"
                          },
                          "resultMsg": {
                            "type": "string",
                            "description": "接口返回说明"
                          },
                          "resultObject": {
                            "type": "object",
                            "properties": {
                              "status": {
                                "type": "string",
                                "description": "状态"
                              },
                              "currentStep": {
                                "type": "string",
