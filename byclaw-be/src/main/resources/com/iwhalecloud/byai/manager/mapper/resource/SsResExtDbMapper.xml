<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwhalecloud.byai.manager.mapper.resource.SsResExtDbMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.iwhalecloud.byai.manager.entity.resource.SsResExtDb">
        <id column="resource_id" property="resourceId" />
        <result column="chatbi_base_id" property="chatbiBaseId" />
    </resultMap>

    <!-- 通用查询结果�?-->
    <sql id="Base_Column_List">
        resource_id, chatbi_base_id
    </sql>

    <resultMap id="resourceExtDbDtoResultMap"
               type="com.iwhalecloud.byai.manager.dto.resource.ResourceExtDbDto"
               extends="com.iwhalecloud.byai.manager.mapper.resource.SsResourceMapper.BaseResultMap">
        <association property="ssResExtDb" javaType="com.iwhalecloud.byai.manager.entity.resource.SsResExtDb" resultMap="BaseResultMap" />
    </resultMap>

    <select id="findResourceExtDbByIds" resultMap="resourceExtDbDtoResultMap">
        SELECT a.resource_id,
               a.resource_code,
               a.system_code,
               a.resource_source_pk_id,
               a.resource_biz_type,
               a.resource_type,
               a.resource_name,
               a.resource_desc,
               a.avatar,
               a.sample,
               a.tags,
               a.resource_version_id,
               a.host_type,
               a.catalog_id,
               a.man_org_id,
               a.man_user_id,
               a.index_list,
               a.create_by,
               a.create_time,
               a.update_by,
               a.update_time,
               a.com_acct_id,
               a.resource_status,
               a.resource_d_verid,
               a.resource_r_verid,
               a.auth_status,
               a.publish_time,
               a.shelf_time,
               a.unshelf_time,
               a.publish_portal,
               b.resource_id,
               b.chatbi_base_id
        FROM ss_resource a
        LEFT JOIN ss_res_ext_db b ON a.resource_id = b.resource_id
        WHERE a.resource_biz_type = 'KG_DB'
        AND a.resource_id IN
        <foreach collection="resourceIds" item="item" open="(" separator="," close=")">
            #{item}
        </foreach>
    </select>

</mapper>