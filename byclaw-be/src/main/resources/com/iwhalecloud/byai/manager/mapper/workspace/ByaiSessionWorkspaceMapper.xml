<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwhalecloud.byai.manager.mapper.workspace.ByaiSessionWorkspaceMapper">

    <!-- ByaiSessionWorkspace 结果映射 -->
    <resultMap id="BaseResultMap" type="com.iwhalecloud.byai.manager.entity.workspace.ByaiSessionWorkspace">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="session_id" property="sessionId" jdbcType="BIGINT"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="rel_count" property="relCount" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="create_by" property="createBy" jdbcType="BIGINT"/>
        <result column="file_id" property="fileId" jdbcType="VARCHAR"/>
        <result column="file_url" property="fileUrl" jdbcType="VARCHAR"/>
        <result column="icon" property="icon" jdbcType="VARCHAR"/>
        <result column="is_exist" property="isExist" jdbcType="INTEGER"/>
    </resultMap>

    <!-- 批量插入会话工作区（兼容 MySQL / Oracle / PostgreSQL） -->
    <insert id="insertBatch" parameterType="java.util.List">
        INSERT INTO byai_session_workspace (
            id,
            session_id,
            name,
            rel_count,
            create_time,
            create_by,
            file_id,
            file_url,
            icon
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.id},
                #{item.sessionId},
                #{item.name},
                #{item.relCount},
                #{item.createTime},
                #{item.createBy},
                #{item.fileId},
                #{item.fileUrl},
                #{item.icon}
            )
        </foreach>
    </insert>



    <!-- 批量更新 is_exist=1 WHERE id IN (...) -->
    <update id="updateIsExistByIds">
        UPDATE byai_session_workspace
        SET is_exist = 1
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 按会话 id 查询工作区列表，按创建时间倒序 -->
    <select id="selectBySession" resultMap="BaseResultMap">
        SELECT id, session_id, name, rel_count, create_time, create_by, file_id, file_url, icon, is_exist
        FROM byai_session_workspace
        WHERE session_id = #{sessionId}
        <if test="keyword != null and keyword != ''">
            AND name LIKE CONCAT('%', CONCAT(#{keyword}, '%'))
        </if>
        ORDER BY create_time DESC
    </select>
</mapper>
