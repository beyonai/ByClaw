<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwhalecloud.byai.manager.mapper.memory.MemoryLibraryMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.iwhalecloud.byai.manager.entity.memory.MemoryLibrary">
        <id column="library_id" property="libraryId" />
        <result column="mem_library_id" property="memLibraryId" />
        <result column="agent_id" property="agentId" />
        <result column="user_id" property="userId" />
        <result column="library_type" property="libraryType" />
        <result column="is_enabled" property="isEnabled" />
        <result column="create_by" property="createBy" />
        <result column="update_by" property="updateBy" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        library_id, mem_library_id, agent_id, user_id, library_type, is_enabled, create_by, update_by, create_time, update_time
    </sql>

    <!-- 根据用户ID和数字员工ID查询记忆库 -->
    <select id="selectByUserIdAndAgentId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM memory_library
        WHERE agent_id = #{agentId}
        AND library_type = #{libraryType}
        LIMIT 1
    </select>

    <!-- 根据数字员工ID查询记忆库列表 -->
    <select id="selectByAgentId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM memory_library
        WHERE agent_id = #{agentId}
    </select>

    <!-- 根据数字员工ID删除记忆库 -->
    <delete id="deleteByAgentId">
        DELETE FROM memory_library
        WHERE agent_id = #{agentId}
    </delete>

</mapper>

