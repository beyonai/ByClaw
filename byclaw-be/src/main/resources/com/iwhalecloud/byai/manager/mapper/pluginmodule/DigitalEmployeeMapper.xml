<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iwhalecloud.byai.manager.mapper.pluginmodule.DigitalEmployeeMapper">

    <resultMap id="BaseResultMap" type="com.iwhalecloud.byai.manager.entity.pluginmodule.DigitalEmployee">
        <id column="id" property="id"/>
        <result column="employee_code" property="employeeCode"/>
        <result column="employee_name" property="employeeName"/>
        <result column="employee_type" property="employeeType"/>
        <result column="source_system" property="sourceSystem"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByCode" resultMap="BaseResultMap">
        SELECT id, employee_code, employee_name, employee_type, source_system, status, create_time, update_time
        FROM digital_employee
        WHERE employee_code = #{employeeCode}
    </select>

    <select id="existsByCode" resultType="boolean">
        SELECT COUNT(1) > 0
        FROM digital_employee
        WHERE employee_code = #{employeeCode}
    </select>

</mapper>
