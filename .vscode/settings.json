{
  "python.defaultInterpreterPath": "${workspaceFolder}/byclaw-data/.venv/Scripts/python.exe",
  "java.import.exclusions": [
    "**/node_modules/**",
    "**/.git/**",
    "**/byclaw-fe/**",
    "**/byclaw-qa/**",
    "**/byclaw-data/**",
    "**/byclaw-exe/**"
  ],
  "java.project.sourcePaths": [
