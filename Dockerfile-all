# =============================================================================
# Dockerfile-all — 将 byclaw-fe / byclaw-be / byclaw-qa / byclaw-data 四个模块合并到一个镜像
#
# 所有模块在镜像内构建，Jenkins 只需：
#   docker build -f Dockerfile-all -t byclaw-all:latest .
#
# 运行：
#   docker run -d -p 8080:8080 -p 8086:8086 -p 8087:8087 -p 8090:8090 \
#     --env-file .env \
#     -v $(pwd)/nginx.conf:/etc/nginx/conf.d/default.conf \
#     byclaw-all:latest
#
# 端口说明：
#   8080 — nginx (前端)
#   8086 — Spring Boot (后端)
#   8087 — byclaw-data MCP / REST (Python)
#   8090 — byclaw-qa API (Python)
# =============================================================================

# ---------------------------------------------------------------------------
# Stage 1: 构建前端
# ---------------------------------------------------------------------------
FROM node:20-alpine AS fe-build

RUN corepack enable && corepack prepare pnpm@9 --activate
ENV HUSKY=0
WORKDIR /build

COPY byclaw-fe/package.json byclaw-fe/pnpm-lock.yaml byclaw-fe/.npmrc ./
RUN pnpm install --frozen-lockfile --ignore-scripts

COPY byclaw-fe/ ./
RUN pnpm run postinstall && pnpm run build

# ---------------------------------------------------------------------------
# Stage 2: 构建后端
# ---------------------------------------------------------------------------
FROM maven:3.9-eclipse-temurin-21-alpine AS be-build

WORKDIR /build
COPY byclaw-be/pom.xml ./
RUN --mount=type=cache,target=/root/.m2 mvn -B dependency:go-offline

COPY byclaw-be/ ./
RUN --mount=type=cache,target=/root/.m2 mvn -B package -DskipTests

# ---------------------------------------------------------------------------
# Stage 3: 构建 QA Python 依赖 (在构建阶段完成 uv sync)
# ---------------------------------------------------------------------------
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS qa-build

ENV UV_COMPILE_BYTECODE=0 \
    UV_LINK_MODE=copy \
    PYTHONUNBUFFERED=1

WORKDIR /app/qa
COPY byclaw-qa/pyproject.toml byclaw-qa/uv.lock byclaw-qa/README.md ./
RUN uv sync --frozen --no-dev --no-install-project && \
    # 清理 uv 缓存
    rm -rf /root/.cache/uv && \
    # 清理 Python 包中的测试、文档、__pycache__
    find .venv -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null; \
    find .venv -type d -name "tests" -exec rm -rf {} + 2>/dev/null; \
    find .venv -type d -name "test" -exec rm -rf {} + 2>/dev/null; \
    find .venv -type d -name "docs" -exec rm -rf {} + 2>/dev/null; \
    find .venv -path "*/dist-info/RECORD" -delete 2>/dev/null; \
    true

COPY byclaw-qa/redis_agent_config.py byclaw-qa/redis_model_config.py byclaw-qa/minio_client.py byclaw-qa/minio_agent_config.py byclaw-qa/api.py byclaw-qa/start.sh byclaw-qa/worker.py ./

# ---------------------------------------------------------------------------
# Stage 4: Nginx 运行时 (Debian 变体，glibc 兼容)
# ---------------------------------------------------------------------------
FROM nginx:1.27-bookworm AS fe-base

# ---------------------------------------------------------------------------
# Stage 4.5: 构建 byclaw-data Python 依赖 (在构建阶段完成 uv sync)
# ---------------------------------------------------------------------------
FROM ghcr.io/astral-sh/uv:python3.12-bookworm-slim AS data-build

ENV UV_COMPILE_BYTECODE=0 \
    UV_LINK_MODE=copy \
    PYTHONUNBUFFERED=1

WORKDIR /app/data
COPY byclaw-data/pyproject.toml byclaw-data/uv.lock byclaw-data/README.md byclaw-data/start.sh ./
COPY byclaw-data/src ./src
RUN chmod +x start.sh && \
    uv sync --frozen --no-dev && \
    rm -rf /root/.cache/uv && \
    find .venv -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null && \
    find .venv -type d -name "docs" -exec rm -rf {} + 2>/dev/null && \
    find .venv -path "*/dist-info/RECORD" -delete 2>/dev/null && \
    true

# ---------------------------------------------------------------------------
# Stage 5: 裁剪 JRE (jlink, Debian 变体避免 musl 兼容问题)
# ---------------------------------------------------------------------------
FROM eclipse-temurin:21-jdk-jammy AS jre-build

RUN jlink \
    --add-modules java.base,java.desktop,java.instrument,java.logging,\
java.management,java.naming,java.net.http,java.security.jgss,\
java.security.sasl,java.sql,java.xml,jdk.crypto.ec,jdk.unsupported,\
jdk.httpserver \
    --strip-debug \
    --no-man-pages \
    --no-header-files \
    --compress=zip-6 \
    --output /opt/jre-minimal

# ---------------------------------------------------------------------------
# Stage 6: 最终运行镜像 (Debian bookworm-slim，兼容所有运行时)
# ---------------------------------------------------------------------------
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8

# 安装 supervisor + 必要工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        supervisor curl ca-certificates vim procps && \
    rm -rf /var/lib/apt/lists/*

# ---- Nginx (from fe-base, Debian glibc 兼容) ------------------------------
COPY --from=fe-base /usr/sbin/nginx /usr/sbin/nginx
COPY --from=fe-base /usr/lib/nginx/ /usr/lib/nginx/
COPY --from=fe-base /etc/nginx/ /etc/nginx/
COPY --from=fe-base /usr/share/nginx/html /usr/share/nginx/html
COPY --from=fe-base /var/cache/nginx /var/cache/nginx
COPY --from=fe-base /var/log/nginx /var/log/nginx
RUN mkdir -p /run/nginx /var/log/nginx && \
    ln -sf /dev/stdout /var/log/nginx/access.log && \
    ln -sf /dev/stderr /var/log/nginx/error.log && \
    sed -i 's/^\s*user .*/user root;/' /etc/nginx/nginx.conf

# 复制前端构建产物 (from fe-build)
COPY --from=fe-build /build/dist/ /usr/share/nginx/html/

# ---- 裁剪版 JRE (from jre-build) -----------------------------------------
ENV JAVA_HOME=/opt/java/openjdk
ENV PATH="${JAVA_HOME}/bin:${PATH}"
COPY --from=jre-build /opt/jre-minimal ${JAVA_HOME}

# 复制后端 JAR (from be-build)
WORKDIR /app/be
COPY --from=be-build /build/target/*.jar app.jar

# ---- Python + QA 已安装的 .venv (from qa-build) ---------------------------
COPY --from=qa-build /usr/local/bin/python3 /usr/local/bin/python3
COPY --from=qa-build /usr/local/bin/python3.12 /usr/local/bin/python3.12
COPY --from=qa-build /usr/local/lib/libpython3.12.so.1.0 /usr/local/lib/libpython3.12.so.1.0
COPY --from=qa-build /usr/local/lib/python3.12/ /usr/local/lib/python3.12/
RUN ln -sf /usr/local/bin/python3 /usr/local/bin/python && \
    ln -sf /usr/local/lib/libpython3.12.so.1.0 /usr/local/lib/libpython3.12.so && \
    ln -sf /usr/local/lib/libpython3.12.so /usr/local/lib/libpython3.so && \
    ldconfig

# 直接复制已安装好的 .venv 和源码 (不需要 uv 二进制)
WORKDIR /app/qa
COPY --from=qa-build /app/qa/ ./
ENV PYTHONUNBUFFERED=1

# ---- byclaw-data 已安装的 .venv 和源码 (from data-build) ------------------
ENV DATACLOUD_DATA_SERVICE_HOST=0.0.0.0 \
    DATACLOUD_DATA_SERVICE_PORT=8087 \
    DATACLOUD_DATA_SERVICE_URL=http://127.0.0.1:8087 \
    DATACLOUD_API_BASE_URL=http://127.0.0.1:8087 \
    DATACLOUD_LOG_DIR=/var/log/byclaw-data
WORKDIR /app/data
COPY --from=data-build /app/data/ ./

# ---- Supervisord 配置 -----------------------------------------------------
RUN mkdir -p /var/log/supervisor /var/log/byclaw-data
COPY <<'SUPERVISORD_CONF' /etc/supervisor/conf.d/byclaw-all.conf
[supervisord]
nodaemon=true
user=root
logfile=/var/log/supervisor/supervisord.log
pidfile=/var/run/supervisord.pid
loglevel=info

[program:nginx]
command=/usr/sbin/nginx -g "daemon off;"
autostart=true
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=10

[program:backend]
command=java -jar /app/be/app.jar
directory=/app/be
autostart=true
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=20

[program:qa-api]
command=bash /app/qa/start.sh api
directory=/app/qa
autostart=true
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=30

[program:datacloud]
command=bash /app/data/start.sh
directory=/app/data
autostart=true
autorestart=true
stdout_logfile=/dev/stdout
stdout_logfile_maxbytes=0
stderr_logfile=/dev/stderr
stderr_logfile_maxbytes=0
priority=40
SUPERVISORD_CONF

# ---- 端口 & 健康检查 -------------------------------------------------------
EXPOSE 8080 8086 8087 8090

HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
    CMD curl -f http://localhost:8080/ && \
        curl -f http://localhost:8086/byaiService/actuator/health && \
        curl -f http://localhost:8087/health || exit 1

WORKDIR /app
CMD ["supervisord", "-c", "/etc/supervisor/supervisord.conf"]
