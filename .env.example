# GHCR (GitHub Container Registry)
GHCR_USER=your_github_username
GHCR_TOKEN=your_ghcr_personal_access_token

# Domain name
BE_DOMAINNAME=ByaiService
QA_DOMAINNAME=byclaw-qa-manager
DATACLOUD_DOMAINNAME=byclaw-datacloud

# Server
HOST=127.0.0.1
BE_SERVER_PORT=8086
BE_WS_PORT=8082
BYCLAW_QA_PORT=8000
DATACLOUD_PORT=8088

# Database
DB_TYPE=postgresql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=postgres
DB_SCHEMA=byai
DB_USER=gaussdb
DB_PASS=Admin@123

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=admin123
REDIS_DATABASE=0

# Storage type
FILE_STORAGE_TYPE=minio

# MinIO
FILE_STORAGE_MINIO_HOST=127.0.0.1
FILE_STORAGE_MINIO_API_PORT=9009
FILE_STORAGE_MINIO_UI_PORT=9019
FILE_STORAGE_MINIO_ACCESS_KEY=your_minio_access_key
FILE_STORAGE_MINIO_SECRET_KEY=your_minio_secret_key
FILE_STORAGE_MINIO_SECURE=false
FILE_STORAGE_MINIO_BUCKET_NAME=byclaw

# Enables MinIO bucket mounting during application startup.
FILE_STORAGE_MINIO_MOUNT_ENABLED=true
FILE_STORAGE_MINIO_MOUNT_PATH=your_mount_path

# Enables mounting on the first configured host target (mount.targets[0]).
FILE_STORAGE_MINIO_MOUNT_TARGET_0_ENABLED=true
FILE_STORAGE_MINIO_MOUNT_TARGET_0_HOST=your_mount_host
FILE_STORAGE_MINIO_MOUNT_TARGET_0_PORT=22
FILE_STORAGE_MINIO_MOUNT_TARGET_0_USER=your_ftp_username
FILE_STORAGE_MINIO_MOUNT_TARGET_0_PASSWORD=your_ftp_password


# SANDBOX
BYCLAW_SANDBOX_ENABLE=true
BYCLAW_SANDBOX_BASE_URL=http://127.0.0.1:8090
BYCLAW_SANDBOX_API_KEY=dev
BYCLAW_SANDBOX_ENDPOINT_SCHEME=http
BYCLAW_SANDBOX_PERMANENT_KEEP=true
BYCLAW_SANDBOX_STORAGE_MODE=sftp
BYCLAW_SANDBOX_HEARTBEAT_TIMEOUT=PT5M

AGENT_POOL_BASE_URL=http://127.0.0.1:8087
AGENT_POOL_TOKEN=< your agent pool token >

# DingTalk Stream Bot
DINGTALK_STREAM_ENABLE=false

# init user's resources to redis after the server start
INIT_USER_AUTH_RESOURCES_REDIS_ENABLED=true

# =========================================================
# byclaw-qa shared runtime variables
# These variables are defined at the repo level with the
# fixed `BYCLAW_QA_` prefix and mapped by `byclaw-qa/start.sh`
# to the variable names expected by the Q&A application.
# =========================================================
BYCLAW_QA_AGENT_DATA_PATH=agent_data

BYCLAW_QA_KB_FETCH_CACHE_TTL_SECONDS=86400
BYCLAW_QA_KB_FETCH_CACHE_CLEANUP_INTERVAL_SECONDS=600

BYCLAW_QA_KB_MINIO_BUCKET=knowledge-base
BYCLAW_QA_KB_MINIO_MARKDOWN_BUCKET=knowledge-base-markdown

BYCLAW_QA_BYAI_WORKER_ID=instant-search-worker-1

# ============================================================
# whale-datacloud 推荐 .env 清单
# 说明：
# 1. 只保留当前主运行时代码仍会读取的环境变量
# 2. 每个变量前一行是说明
# 3. 可选项保留为空或注释掉
# ============================================================


# ============================================================
# 一、数据库配置
# ============================================================


# 数据库连接超时（秒），主要用于 knowledge 导入
DATACLOUD_DB_CONNECT_TIMEOUT=30

# 数据库锁等待超时（毫秒），主要用于 knowledge 导入
DATACLOUD_DB_LOCK_TIMEOUT_MS=30000


# ============================================================
# 三、Agent / Analysis 配置
# ============================================================

# Agent 语言地区
DATACLOUD_AGENT_LOCALE=zh_CN

# 是否禁用 ask_user 工具：1=true，0=false
DATACLOUD_DISABLE_ASK_USER_TOOL=1

# ReAct 最大轮数
DATACLOUD_REACT_MAX_ROUNDS=10

# 最终输出格式，常见值：markdown
DATACLOUD_OUTPUT_FORMAT=markdown

# 命令插件目录，可多个，按约定分隔
DATACLOUD_COMMAND_PLUGIN_DIRS=

# 工具 Hook 插件目录，可多个，按约定分隔
DATACLOUD_TOOL_HOOK_PLUGIN_DIRS=

# 是否启用预构建 ReAct 路径
DATACLOUD_USE_PREBUILT_REACT=false

# 历史对话轮数
DATACLOUD_HISTORY_MESSAGE_LIMIT=6


# ============================================================
# 四、Gateway / Worker 配置
# ============================================================


# Worker 节点标识
DATACLOUD_GATEWAY_WORKER_ID=datacloud

DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud


# ============================================================
# 五、Data Service 配置
# ============================================================

# 查询结果超过多少行时落 CSV，同时预览只返回前 N 行
DATACLOUD_QUERY_RESULT_CSV_THRESHOLD=5


# 查询计划生成最大重试次数
DATACLOUD_MAX_PLAN_RETRIES=2


# static：不自动重载，也不启动 watcher、 lazy：请求时检查变化并重载，但不启动 watcher、watch：启动 watcher，且保留自动重载能力
DATACLOUD_LOADER_MODE=watch

# watch时才生效
DATACLOUD_LOADER_RELOAD_DEBOUNCE_MS=500

# CORS 白名单，多个用逗号分隔
DATACLOUD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ============================================================
# 六、日志配置
# ============================================================

# 日志目录
DATACLOUD_LOG_DIR=./logs

# 日志级别：DEBUG / INFO / WARNING / ERROR
DATACLOUD_LOG_LEVEL=INFO

# app.log 保留天数
DATACLOUD_LOG_APP_KEEP=30

# error.log 保留天数
DATACLOUD_LOG_ERROR_KEEP=90
