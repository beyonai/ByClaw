# ============================================================
# whale-datacloud 推荐 .env 清单
# 说明：
# 1. 只保留当前主运行时代码仍会读取的环境变量
# 2. 每个变量前一行是说明
# 3. 可选项保留为空或注释掉
# ============================================================

# 说明:一般只需要修改数据库配置、Redis配置、模型配置、资源路径配置,其他配置可以不修改

# ============================================================
# 一、数据库配置
# ============================================================

# 数据库主机（注意根据start.sh脚本启动时环境变量用DB_HOST也可以，非start.sh脚本启动需要叫DATACLOUD_DB_HOST）
DB_HOST=127.0.0.1

# 数据库端口（注意根据start.sh脚本启动时环境变量用DB_PORT也可以，非start.sh脚本启动需要叫DATACLOUD_DB_PORT）
DB_PORT=5432

# 数据库名（注意根据start.sh脚本启动时环境变量用DB_DATABASE也可以，非start.sh脚本启动需要叫DATACLOUD_DB_DATABASE）
DB_DATABASE=postgres

# 数据库 schema（注意根据start.sh脚本启动时环境变量用DB_SCHEMA也可以，非start.sh脚本启动需要叫DATACLOUD_DB_SCHEMA）
DB_SCHEMA=public

# 数据库用户名（注意根据start.sh脚本启动时环境变量用DB_USER也可以，非start.sh脚本启动需要叫DATACLOUD_DB_USER）
DB_USER=postgres

# 数据库密码（注意根据start.sh脚本启动时环境变量用DB_PASS也可以，非start.sh脚本启动需要叫DATACLOUD_DB_PASSWORD）
DB_PASS=

# 数据库类型，常见值：postgresql / opengauss（注意根据start.sh脚本启动时环境变量用DB_TYPE也可以，非start.sh脚本启动需要叫DATACLOUD_DB_TYPE）
DB_TYPE=postgresql

# 数据库连接超时（秒），主要用于 knowledge 导入
DATACLOUD_DB_CONNECT_TIMEOUT=30

# 数据库锁等待超时（毫秒），主要用于 knowledge 导入
DATACLOUD_DB_LOCK_TIMEOUT_MS=30000

# ============================================================
# 二、Gateway / Worker / Redis 配置
# ============================================================

# Gateway Redis 主机（注意根据start.sh脚本启动时环境变量用REDIS_HOST也可以，非start.sh脚本启动需要叫DATACLOUD_GATEWAY_REDIS_HOST）
REDIS_HOST=127.0.0.1

# Gateway Redis 端口（注意根据start.sh脚本启动时环境变量用REDIS_PORT也可以，非start.sh脚本启动需要叫DATACLOUD_GATEWAY_REDIS_PORT）
REDIS_PORT=6379

# Gateway Redis 用户名（注意根据start.sh脚本启动时环境变量用REDIS_USERNAME也可以，非start.sh脚本启动需要叫DATACLOUD_GATEWAY_REDIS_USERNAME）
REDIS_USERNAME=

# Gateway Redis 密码（注意根据start.sh脚本启动时环境变量用REDIS_PASSWORD也可以，非start.sh脚本启动需要叫DATACLOUD_GATEWAY_REDIS_PASSWORD）
REDIS_PASSWORD=

# Gateway Redis DB（注意根据start.sh脚本启动时环境变量用REDIS_DATABASE也可以，非start.sh脚本启动需要叫DATACLOUD_GATEWAY_REDIS_DB）
REDIS_DB=0


# Worker 节点标识(默认使用BYCLAW_DATA即可，一般不需要修改)
DATACLOUD_GATEWAY_WORKER_ID=BYCLAW_DATA

# Gateway 消费者组(默认使用datacloud即可，一般不需要修改)
DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud


# ============================================================
# 三、模型配置
# ============================================================

# 模型信息获取方式：LOCAL（本地环境变量，需要配置DATACLOUD_LLM_MODEL、DATACLOUD_LLM_API_BASE、DATACLOUD_LLM_API_KEY、DATACLOUD_EMBEDDING_API_BASE、DATACLOUD_EMBEDDING_API_KEY、DATACLOUD_EMBEDDING_MODEL） / ONLINE（在线从redis获取不需要配置模型信息）
# 默认redis中获取

# ============================================================
# 五、资源路径配置
# ============================================================

# MINIO资源挂在路径和桶名称（如果通过start.sh脚本启动时环境变量用FILE_STORAGE_MINIO_BUCKET_NAME、FILE_STORAGE_MINIO_MOUNT_PATH即可，非start.sh脚本启动需要DATACLOUD_MID_FTP_PATH、DATACLOUD_ONTOLOGY_PATH）
FILE_STORAGE_MINIO_BUCKET_NAME=byclaw
FILE_STORAGE_MINIO_MOUNT_PATH=your_mount_path

# ============================================================
# 六、Agent / Analysis 配置
# ============================================================

# 是否禁用 ask_user 工具：1=true，0=false
DATACLOUD_DISABLE_ASK_USER_TOOL=1

# ReAct 最大轮数
DATACLOUD_REACT_MAX_ROUNDS=10

# 最终输出格式，常见值：markdown
DATACLOUD_OUTPUT_FORMAT=markdown

# 命令插件目录，可多个，按约定分隔
DATACLOUD_COMMAND_PLUGIN_DIRS=

# 工具 Hook 插件目录，可多个，按约定分隔
DATACLOUD_TOOL_HOOK_PLUGIN_DIRS=

# 是否启用预构建 ReAct 路径
DATACLOUD_USE_PREBUILT_REACT=false

# 是否开启意图澄清 wrapper 0 不开启 1 开启
DATACLOUD_ENABLE_PARADIGM_WRAPPER=0
DATACLOUD_HISTORY_MESSAGE_LIMIT=6


# ============================================================
# 七、Data Service 配置
# ============================================================

# CSV 导出根目录
DATACLOUD_CSV_BASE_DIR=./tmp/csv

# 查询结果超过多少行时落 CSV，同时预览只返回前 N 行
DATACLOUD_QUERY_RESULT_CSV_THRESHOLD=5

# 查询计划生成最大重试次数
DATACLOUD_MAX_PLAN_RETRIES=2


# static：不自动重载，也不启动 watcher、 lazy：请求时检查变化并重载，但不启动 watcher、watch：启动 watcher，且保留自动重载能力
DATACLOUD_LOADER_MODE=watch

# watch时才生效
DATACLOUD_LOADER_RELOAD_DEBOUNCE_MS=500

# CORS 白名单，多个用逗号分隔
DATACLOUD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================================
# 八、日志配置
# ============================================================

# 日志目录
DATACLOUD_LOG_DIR=./logs

# 日志级别：DEBUG / INFO / WARNING / ERROR
DATACLOUD_LOG_LEVEL=INFO

# app.log 保留天数
DATACLOUD_LOG_APP_KEEP=30

# error.log 保留天数
DATACLOUD_LOG_ERROR_KEEP=90


# 服务发现名称和端口
BE_DOMAINNAME=ByaiService

DATACLOUD_DOMAINNAME=byclaw-datacloud

HOST=127.0.0.1

DATACLOUD_PORT=8087

# HOST=10.10.168.203
BE_SERVER_PORT=8888
