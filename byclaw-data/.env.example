# ============================================================
# whale-datacloud 推荐 .env 清单
# 说明：
# 1. 只保留当前主运行时代码仍会读取的环境变量
# 2. 每个变量前一行是说明
# 3. 可选项保留为空或注释掉
# ============================================================


# ============================================================
# 一、数据库配置
# ============================================================

# 数据库主机
DATACLOUD_DB_HOST=127.0.0.1

# 数据库端口
DATACLOUD_DB_PORT=5432

# 数据库名
DATACLOUD_DB_DATABASE=postgres

# 数据库 schema
DATACLOUD_DB_SCHEMA=public

# 数据库用户名
DATACLOUD_DB_USER=postgres

# 数据库密码
DATACLOUD_DB_PASSWORD=

# 数据库类型，常见值：postgresql / opengauss
DATACLOUD_DB_TYPE=postgresql

# 数据库连接超时（秒），主要用于 knowledge 导入
DATACLOUD_DB_CONNECT_TIMEOUT=30

# 数据库锁等待超时（毫秒），主要用于 knowledge 导入
DATACLOUD_DB_LOCK_TIMEOUT_MS=30000


# ============================================================
# 二、LLM 配置
# ============================================================

# LLM API Base URL
DATACLOUD_LLM_API_BASE=https://your-llm-proxy/v1

# LLM API Key
DATACLOUD_LLM_API_KEY=

# LLM 模型名
DATACLOUD_LLM_MODEL=gpt-4o

# LLM 温度
DATACLOUD_LLM_TEMPERATURE=0.0

# LLM 协议类型：openai / anthropic
DATACLOUD_LLM_MODEL_PROVIDER=openai

# 额外模型参数，JSON 字符串，可选
# DATACLOUD_LLM_MODEL_KWARGS={"max_tokens":8192}


# ============================================================
# 三、Agent / Analysis 配置
# ============================================================

# Agent 语言地区
DATACLOUD_AGENT_LOCALE=zh_CN

# 是否禁用 ask_user 工具：1=true，0=false
DATACLOUD_DISABLE_ASK_USER_TOOL=1

# ReAct 最大轮数
DATACLOUD_REACT_MAX_ROUNDS=10

# 最终输出格式，常见值：markdown
DATACLOUD_OUTPUT_FORMAT=markdown

# 命令插件目录，可多个，按约定分隔
DATACLOUD_COMMAND_PLUGIN_DIRS=

# 工具 Hook 插件目录，可多个，按约定分隔
DATACLOUD_TOOL_HOOK_PLUGIN_DIRS=

# 是否启用预构建 ReAct 路径
DATACLOUD_USE_PREBUILT_REACT=false

# 数字员工配置
DATACLOUD_MID_FTP_PATH=/Users/zouhaitian/Documents/workplace/project/Haojing/baiyin_ai_v2/by-datacloud/packages/datacloud-data/src/datacloud_data_service/resource/agents
# 是否开启意图澄清 wrapper 0 不开启 1 开启
DATACLOUD_ENABLE_PARADIGM_WRAPPER=0
DATACLOUD_HISTORY_MESSAGE_LIMIT=6


# ============================================================
# 四、Gateway / Worker 配置
# ============================================================

# Gateway Redis 主机
DATACLOUD_GATEWAY_REDIS_HOST=127.0.0.1

# Gateway Redis 端口
DATACLOUD_GATEWAY_REDIS_PORT=6379

# Gateway Redis 用户名
DATACLOUD_GATEWAY_REDIS_USERNAME=

# Gateway Redis 密码
DATACLOUD_GATEWAY_REDIS_PASSWORD=

# Gateway Redis DB
DATACLOUD_GATEWAY_REDIS_DB=0

# Worker 节点标识
DATACLOUD_GATEWAY_WORKER_ID=datacloud

DATACLOUD_GATEWAY_CONSUMER_GROUP=datacloud

DATACLOUD_GATEWAY_WORKSPACE_DIR=/tmp/datacloud


# ============================================================
# 五、Data Service 配置
# ============================================================

# 本体资源路径，可为文件或目录
DATACLOUD_ONTOLOGY_PATH=./packages/datacloud-data/src/datacloud_data_service/resource

# CSV 导出根目录
DATACLOUD_CSV_BASE_DIR=./tmp/csv

# 查询结果超过多少行时落 CSV，同时预览只返回前 N 行
DATACLOUD_QUERY_RESULT_CSV_THRESHOLD=5

# 对外 API 基础地址
DATACLOUD_API_BASE_URL=http://127.0.0.1:8080

# 查询计划生成最大重试次数
DATACLOUD_MAX_PLAN_RETRIES=2


# static：不自动重载，也不启动 watcher、 lazy：请求时检查变化并重载，但不启动 watcher、watch：启动 watcher，且保留自动重载能力
DATACLOUD_LOADER_MODE=watch

# watch时才生效
DATACLOUD_LOADER_RELOAD_DEBOUNCE_MS=500

# CORS 白名单，多个用逗号分隔
DATACLOUD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ============================================================
# 六、日志配置
# ============================================================

# 日志目录
DATACLOUD_LOG_DIR=./logs

# 日志级别：DEBUG / INFO / WARNING / ERROR
DATACLOUD_LOG_LEVEL=INFO

# app.log 保留天数
DATACLOUD_LOG_APP_KEEP=30

# error.log 保留天数
DATACLOUD_LOG_ERROR_KEEP=90


# ============================================================
# 七、Knowledge / Intent / Embedding 配置
# ============================================================

# 是否采集确认/澄清样本：1=true，0=false
DATACLOUD_COLLECT_CONFIRM_CASES=0

# Embedding API Base URL
DATACLOUD_EMBEDDING_API_BASE=

# Embedding API Key
DATACLOUD_EMBEDDING_API_KEY=

# Embedding 模型名
DATACLOUD_EMBEDDING_MODEL=

# Embedding 批大小
DATACLOUD_EMBEDDING_BATCH_SIZE=10

# Embedding 向量维度
DATACLOUD_EMBEDDING_DIMS=1024

BE_DOMAINNAME_URL=http://xxxx:8888

DATACLOUD_DOMAINNAME=byclaw-datacloud

HOST=10.45.134.164

DATACLOUD_PORT=8087

# HOST=10.10.168.203
BE_SERVER_PORT=8888