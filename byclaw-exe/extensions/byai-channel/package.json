{
  "name": "byai-channel",
  "version": "1.0.0",
  "description": "ByAI Channel - HTTP Webhook + Redis SDK channel with configurable streaming support",
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --sourcemap --external:openclaw --external:minio"
  },
  "dependencies": {
    "@byclaw/by-framework": "^1.3.1",
    "esbuild": "^0.25.0",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "byai-channel",
      "label": "ByAI Channel",
      "selectionLabel": "ByAI Channel (HTTP + Redis SDK)",
      "docsPath": "/channels/byai-channel",
      "docsLabel": "byai-channel",
      "blurb": "HTTP webhook + Redis SDK channel with configurable streaming output for web integration.",
      "order": 86
    }
  }
}
